{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "pinDigests": false,
  "packageRules": [
    {
      "matchPackageNames": [
        "ghcr.io/openclaw/openclaw",
        "openclaw/openclaw"
      ],
      "groupName": "openclaw base image",
      "semanticCommitType": "feat",
      "semanticCommitScope": "openclaw"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yml$/"
      ],
      "matchStrings": [
        "DEFAULT_BASE_IMAGE:\\s*ghcr\\.io/(?<depName>[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://ghcr.io"
    }
  ]
}

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "pinDigests": false,
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/openclaw/openclaw", "openclaw/openclaw"],
      "groupName": "openclaw base image"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.*\\.yml$"],
      "matchStrings": [
        "DEFAULT_BASE_IMAGE:\\s*ghcr\\.io/(?<depName>[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://ghcr.io"
    }
  ]
}
